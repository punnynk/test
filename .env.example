# =============================================================================
# .env — ตัวแปรควบคุมทั้งหมด (แก้ที่นี่ที่เดียว)
# =============================================================================

# ── Paths ─────────────────────────────────────────────────────────────────────
LABELED_FILE=labeled.csv
UNLABELED_FILE=unlabeled.csv
DAPT_OUTPUT_DIR=output/dapt_backbone
SUPERVISED_OUTPUT_DIR=output/supervised
SELFTRAINING_OUTPUT_DIR=output/selftraining
LOG_DIR=runs

# ── Column Names ──────────────────────────────────────────────────────────────
TEXT_COLUMN=text
LABEL_COLUMN=labels
# vote columns: class_0, class_1, ..., class_5 (สร้างอัตโนมัติจาก NUM_CLASSES)
VOTE_COLUMN_PREFIX=class_

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_NAME=rinna/japanese-roberta-base
USE_FAST_TOKENIZER=false
MAX_SEQ_LEN=510
HIDDEN_DIM=768
NUM_ATTENTION_HEADS=8
NUM_GAL_LAYERS=2
LCF_MODE=cdm
NUM_CLASSES=6
DROPOUT=0.1

# ── DAPT (ไฟล์ 1) ─────────────────────────────────────────────────────────────
DAPT_BATCH_SIZE=16
DAPT_EPOCHS=3
DAPT_LR=1e-4
DAPT_WEIGHT_DECAY=0.01
DAPT_WARMUP_RATIO=0.1
DAPT_MAX_GRAD_NORM=1.0
DAPT_MLM_PROB=0.15
DAPT_START_LINE=0
# DAPT_END_LINE: ว่าง = อ่านจนจบไฟล์
DAPT_END_LINE=

# ── Supervised (ไฟล์ 2) ───────────────────────────────────────────────────────
SUP_BATCH_SIZE=16
SUP_EPOCHS=10
BACKBONE_LR=2e-5
GAL_LR=1e-4
SUP_WEIGHT_DECAY=0.01
SUP_WARMUP_RATIO=0.1
SUP_MAX_GRAD_NORM=1.0
SUP_VAL_SPLIT=0.1
# SAMPLE_WEIGHT_MIN: ค่าต่ำสุดของ sample_weight (กัน 0)
SAMPLE_WEIGHT_MIN=0.1
# GOLD_SPLIT: สัดส่วน gold eval set ต่อ data ทั้งหมด (stratified)
GOLD_SPLIT=0.15

# ── Self-training (ไฟล์ 3) ────────────────────────────────────────────────────
ST_CONFIDENCE_THRESHOLD=0.7
# ST_RATIO_CAP: unlabeled:labeled ต่อ batch สูงสุด
ST_RATIO_CAP=3
ST_MAX_ROUNDS=10
# ST_PATIENCE: หยุดถ้า val F1 ไม่ขึ้น N รอบติด
ST_PATIENCE=2
ST_BACKBONE_LR=1e-5
ST_GAL_LR=5e-5
ST_WEIGHT_DECAY=0.01
ST_WARMUP_RATIO=0.05
ST_MAX_GRAD_NORM=1.0
ST_EPOCHS_PER_ROUND=1
ST_BATCH_SIZE=16
ST_UNLABELED_START_LINE=0
# ST_UNLABELED_END_LINE: ว่าง = อ่านจนจบไฟล์
ST_UNLABELED_END_LINE=

# ── Hardware ──────────────────────────────────────────────────────────────────
# NUM_GPUS: 0 = ใช้ทุก GPU ที่มี | N = ใช้ N การ์ดแรก | 1 = single GPU
NUM_GPUS=None
RANDOM_SEED=99